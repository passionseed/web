      "program_id": "10090271211001A",
      "project_id": "G0001",
      "project_name_th": "โครงการเด็กดีมีที่เรียน",
      "type": "1_2569",
      "receive_student_number": 34,
      "only_formal": 1,
      "only_international": 1,
      "only_vocational": 1,
      "only_non_formal": 1,
      "only_ged": 1,
      "condition": "เฉพาะผู้สมัครที่จบจากโรงเรียนหลักสูตรแกนกลางเท่านั้น จะต้องมีจำนวนหน่วยกิตวิชากลุ่มสาระการเรียนรู้ คณิตศาสตร์ ไม่ต่ำกว่า 12 / วิทยาศาสตร์และเทคโนโลยี ไม่ต่ำกว่า 22 / ภาษาต่างประเทศ ไม่ต่ำกว่า 9",
      "link": "https://admission.swu.ac.th",
      "grad_current": false,
      "t_score": false,
      "min_gpax": 2,
      "min_credit_gpa22": 12,
      "min_credit_gpa23": 22,
      "min_credit_gpa28": 9,
      "score_conditions": {
        "min_gpax": 2
      },
      "folio": {
        "folio_q1": "เรียงความเป็นภาษาไทย แสดงความมุ่งมั่น/ สนใจในสาขาวิชาที่สมัคร ครอบคลุมหัวข้อต่อไปนี้\n1) เป้าหมายในชีวิต/ อาชีพ/ สิ่งที่อยากทำหลังเรียนจบ\n2) ธุรกิจ/ อาชีพของครอบครัว หรือผู้ปกครอง\n3) ประสบการณ์การทำงานพิเศษ/ การทำธุรกิจของตนเอง",
        "folio_q1_type": "B",
        "folio_q2": "การตอบคำถามเกี่ยวกับลักษณะนิสัย เป็นภาษาไทย\nผู้สมัครคิดว่าตนเองมีลักษณะนิสัยโดดเด่นด้านใด (เลือกเพียง 1 จาก 3 ข้อ) และให้ยกตัวอย่างเหตุการณ์ที่คิดว่าตนเองแสดงลักษณะนิสัยนั้นอย่างชัดเจน\n1) ความพยายามในการบรรลุเป้าหมายของงาน (persistance)\n2) อยากเรียนรู้ กระตือรือร้นในการทำงาน และพัฒนาตนเองอย่างต่อเนื่อง (curiosity)\n3) การปรับตัวให้เข้ากับสถานการณ์ (adaptability)",
        "folio_q2_type": "C",
        "folio_q3": "หนังสือรับรองที่ผู้สมัครจัดทำแบบฟอร์มขึ้นเอง หรือ หนังสือรับรองตามแบบฟอร์มของโรงเรียน ที่รับรองว่าเป็นนักเรียนผู้มีคุณสมบัติตามประกาศของมหาวิทยาลัย: มีผลงานกระทำความดี/มีคุณธรรม/จริยธรรม/บำเพ็ญประโยชน์/อุทิศตนเพื่อส่วนรวม (ไม่ใช่หนังสือรับรองความประพฤติ) โดยมีชื่อ-นามสุกล และตำแหน่งของผู้รับรอง จำนวน 1 ฉบับ จากอาจารย์ประจำชั้น หรือ อาจารย์แนะแนว หรือ อาจารย์ผู้สอน",
        "folio_q3_type": "C",
        "closed_date": "11 ธันวาคม 2568",
        "page_limit": "10"
      },
      "created_at": "2025-10-25T02:22:50.503Z",
      "min_total_score": 0,
      "scores": {
        "portfolio": 50,
